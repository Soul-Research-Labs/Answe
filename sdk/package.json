{
  "name": "@starkprivacy/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for StarkPrivacy — ZK privacy protocol on Starknet",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "starkprivacy": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "DEVNET_URL=http://127.0.0.1:5050/rpc vitest run",
    "lint": "tsc --noEmit",
    "docs": "typedoc"
  },
  "keywords": [
    "starknet",
    "privacy",
    "zk",
    "stark",
    "poseidon"
  ],
  "license": "MIT",
  "dependencies": {
    "starknet": "^6.23.1"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "@types/node": "^22.0.0",
    "typedoc": "^0.27.0"
  }
}
